    "@aws-sdk/client-s3": "^3.1061.0",
    "@aws-sdk/client-secrets-manager": "^3.1061.0",
    "@aws-sdk/client-sfn": "^3.1061.0",
    "@aws-sdk/lib-dynamodb": "^3.1061.0",
